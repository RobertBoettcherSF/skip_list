--  skip_list.gpr
--  
--  GNAT Project File for Skip List SPARK implementation
--  
--  This project file configures the Skip List implementation for
--  compilation with SPARK and GNAT.
--  
--  Version: 0.11
--  Author: Vibe Code Agent
--  Date: 2024

project Skip_List is

   -- Source directories
   for Source_Dirs use (".");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";

   -- Main source file
   for Main use ("skip_list.adb");

   -- Compiler settings for SPARK
   package Compiler is
      for Default_Switches ("Ada") use (
         "-gnatN",       -- No assert pragma suppression
         "-gnatp",       -- Suppress info messages
         "-gnata",       -- Enable assertions
         "-gnatX",       -- Enable SPARK mode
         "-gnatf",       -- Full error messages
         "-gnatC",       -- Enable contract checking
         "-gnatw.e",     -- Warn on unreachable code
         "-gnatw.s",     -- Warn on suspicious conversions
         "-gnatw.x"      -- Warn on unused variables
      );
   end Compiler;

end Skip_List;
